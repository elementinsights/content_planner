# ============================================================================
# seo-planner environment configuration
# Copy to `.env` and fill in only what you have. EVERY provider is optional:
# with no keys the system runs in STRUCTURAL mode and emits a clearly-labeled
# placeholder plan with null metric fields (never fabricated metrics).
# ============================================================================

# ---------------------------------------------------------------------------
# PRIMARY SEO INTELLIGENCE: Ahrefs (preferred)
# Ahrefs API v3 bearer token. Used for keyword discovery, parent topic,
# traffic potential, keyword difficulty, SERP overview, competitor pages,
# organic keywords, referring domains, content gap.
# ---------------------------------------------------------------------------
AHREFS_API_KEY=

# ---------------------------------------------------------------------------
# SECONDARY / SUPPLEMENTAL: DataForSEO (SERP API + volume/trend/clickstream)
# Basic-auth login/password. Used as backup SERP + volume supplement.
# ---------------------------------------------------------------------------
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ---------------------------------------------------------------------------
# OPTIONAL: Semrush (not primary; supported later)
# ---------------------------------------------------------------------------
SEMRUSH_API_KEY=

# ---------------------------------------------------------------------------
# GOOGLE SHEETS (primary human-facing editorial layer)
# Service-account credentials. See docs/SETUP.md for the full walkthrough:
#   1. Create a Google Cloud project.
#   2. Enable the Google Sheets API (and Drive API to create new sheets).
#   3. Create a Service Account; create a JSON key.
#   4. Put the service-account email + private key below.
#   5. Share the target spreadsheet with the service-account email (Editor),
#      OR leave GOOGLE_SHEETS_SPREADSHEET_ID blank to create a new one.
# Provide EITHER the inline client email + private key, OR a path to the JSON.
# ---------------------------------------------------------------------------
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
# Existing spreadsheet to sync into. Leave blank to create a new workbook.
GOOGLE_SHEETS_SPREADSHEET_ID=

# ---------------------------------------------------------------------------
# POST-LAUNCH FEEDBACK (used only after pages exist; not pre-launch research)
# ---------------------------------------------------------------------------
GSC_CREDENTIALS=
GSC_SITE_URL=
GA4_PROPERTY_ID=

# ---------------------------------------------------------------------------
# OPTIONAL LLM for the intake/discovery module.
# If absent, a deterministic intake interpreter is used (no network calls).
# Install the SDK you choose:  npm i @anthropic-ai/sdk   or   npm i openai
# ---------------------------------------------------------------------------
LLM_PROVIDER=deterministic   # deterministic | anthropic | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_VIA_CLAUDE_CODE=false   # true = route LLM calls through Claude Code (subscription, no API credits); API key is the automatic fallback. Slow (~15-30s/call) — best for normal, not exhaustive, runs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Cost controls
# ---------------------------------------------------------------------------
SEO_MAX_PROVIDER_CALLS=2000     # hard cap on external API calls per run
SEO_MAX_LLM_CALLS=20            # hard cap on LLM calls per run
SEO_MAX_USD=25                  # soft budget; run aborts provider calls past this
SEO_SERP_BUDGET=300             # max SERPs fetched (by volume) for SERP-overlap clustering; cached in the DB
SEO_LOG_LEVEL=info              # debug | info | warn | error
SEO_DB_PATH=data/seo-planner.db
